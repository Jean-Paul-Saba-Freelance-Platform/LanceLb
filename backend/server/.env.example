# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use a strong random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=replace_with_32_char_random_string

# ── Environment ───────────────────────────────────────────────────────────────
# Must be exactly "development" or "production" (no typos)
NODE_ENV=development

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Set this to your deployed frontend URL in production
FRONTEND_URL=https://your-frontend.vercel.app

# ── AI — Groq API ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_replace_with_your_groq_api_key

# ── ATS — Flask microservice ──────────────────────────────────────────────────
# Required in production; defaults to http://localhost:5001 in development
FLASK_URL=https://your-flask-service.com

# ── Email (Brevo / SMTP) ──────────────────────────────────────────────────────
SMPTP_USER=your_smtp_username
SMPTP_PASS=your_smtp_password
SENDER_EMAIL=noreply@yourdomain.com
