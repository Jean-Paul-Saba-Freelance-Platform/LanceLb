      "roundness": null,
      "boundElements": [],
      "updated": 1773249990283,
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "POST /api/auth/*         — register, login, verify-otp, reset\nGET  /api/jobs           — public job listings\nGET|POST /api/client/*   — client CRUD\nGET|POST /api/applications/* — create, list, update status\nGET  /api/ai/fit-score/:id   — LLM profile fit analysis\nGET  /api/ai/application-tips/:id  — LLM coaching tips\nPOST /api/ats/evaluate   — PDF upload → ATS score\nGET  /api/ats/health     — Flask health check\nGET|POST /api/message    — DMs  •  /api/crew  — teams\nPOST /api/webhooks       — Stripe payment events",
      "autoResize": true,
      "lineHeight": 1.1666666666666667
    },
