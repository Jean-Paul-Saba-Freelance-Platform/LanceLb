      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "ATS FLOW:  JobCard upload → handleCvUpload() → POST /api/ats/evaluate → multer(memory) → atsService.evaluateResumeWithFlask(buffer) → POST Flask:5001/evaluate → pdfplumber extracts text → scorer.py 6 scorers → ML predict category → { total_score, grade, predicted_category, breakdown, feedback } → shown in modal → stored in Application.atsScore on submit → visible in FreelancerProposalsPage",
      "autoResize": true,
      "lineHeight": 3.3333333333333335
    },
