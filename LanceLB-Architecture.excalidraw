      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "text": "POST /api/auth/*         — register, login, verify-otp, reset\nGET  /api/jobs           — public job listings\nGET|POST /api/client/*   — client CRUD\nGET|POST /api/applications/* — create, list, update status\nGET  /api/ai/fit-score/:id   — LLM profile fit analysis\nGET  /api/ai/application-tips/:id  — LLM coaching tips\nPOST /api/ats/evaluate   — PDF upload → ATS score\nGET  /api/ats/health     — Flask health check\nGET|POST /api/message    — DMs  •  /api/crew  — teams\nPOST /api/webhooks       — Stripe payment events",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 11,
      "seed": 2005,
      "version": 2,
      "versionNonce": 942568754,
      "index": "aP",
