      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "text": "ML Pipeline  model/*.pkl\n  tfidf_vectorizer.pkl  → text → TF-IDF sparse matrix\n  ats_scaler.pkl        → StandardScaler on numeric feats\n  hstack([tfidf_vec, scaled_feats])  → combined input\n  best_ats_model.pkl    → predict(X) → job category\n  label_encoder.pkl     → decode number → category name\n  predict_proba()       → confidence %",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 11,
      "seed": 3008,
      "version": 2,
